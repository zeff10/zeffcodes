#Railfence cipher
msg=input("Enter the message to encrypt: ").replace(" ","")
rails=int(input("Enter the number of rails: "))
def railfence(msg, rails):
    matrix=[['' for j in range(len(msg))] for i in range(rails)]
    row, check=0,0
    for char_index in range(len(msg)):
        if check == 0:
            matrix[row][char_index]=msg[char_index]
            row+=1
            if row==rails:
                check=1
                row-=1
        else:
            row-=1
            matrix[row][char_index]=msg[char_index]
            if row == 0:
                check = 0
                row = 1
    ct=""
    for row in range(rails):
        for char_index in range(len(msg)):
            if matrix[row][char_index] !='':
                ct+=matrix[row][char_index]
    return ct
print("Encrypted Text: ", railfence(msg, rails))


#Columnar cipher
import math
msg=input("Enter the message to encrypt: ").replace(" ","")
key=input("Enter the key: ")
def gen_table(pt, col):
    rows=math.ceil(len(pt)/col)
    dcells=(rows*col)-len(pt)
    pt+='x'*dcells
    table=[]
    for i in range(0, len(pt), col):
        table.append(list(pt[i:i+col]))
    return table
def columnar(pt, keyword):
    ct=""
    index=[]
    matrix=gen_table(pt, len(keyword))
    sorted_keys=sorted(list(keyword))
    for char in sorted_keys:
        for i in range(len(keyword)):
            if keyword[i]==char and i not in index:
                index.append(i)
    for i in index:
        for row in matrix:
            ct+=row[i]
    return ct
ct=columnar(msg, key)
print("Cipher text: "+ct)
