from pynput.keyboard import Key, Listener
def keypress(key):
    print("Key pressed is: ", key)
def keyrelease(key):
    if key == Key.esc:
        return False
with Listener(on_press = keypress, on_release = keyrelease) as Lst:
    Lst.join()
