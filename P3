import pandas as pd 
import seaborn as sns 
import matplotlib.pyplot as plt 

mtcars_df =pd.read_csv("mtcars.csv") 
mtcars_df.head() 

mtcars_df.info() 

 

mtcars_df.tail() 

mtcars_df.isnull().sum() 


mtcars_df.describe() 

 

sns.histplot(mtcars_df["mpg"], bins=10, kde=True) 
plt.xlabel("Miles Per Gallon (MPG)") 
plt.ylabel("Frequency") 
plt.title("Histogram of MPG") 
plt.show()

 

sns.scatterplot(x="disp", y="mpg", data=mtcars_df) 
plt.title("MPG vs Displacement") 
plt.show() 

sns.scatterplot(x="cyl", y="mpg", data=mtcars_df) 
plt.title("MPG vs Cylinders") 
plt.show() 

sns.scatterplot(x="gear", y="mpg", data=mtcars_df) 
plt.title("MPG vs Gears") 
plt.show() 

 

sns.boxplot(x="cyl", y="mpg", data=mtcars_df) 
plt.title("MPG vs Cylinders (Box Plot)") 
plt.show() 

 

sns.boxplot(x="gear", y="mpg", data=mtcars_df) 
plt.title("MPG vs Gears (Box Plot)") 
plt.show() 

 

mtcars_numeric = mtcars_df.select_dtypes(include='number') 
corr = mtcars_numeric.corr() 
corr 

 

sns.heatmap(corr.corr(method="pearson"),annot=True,vmax=1) 
